#!/bin/bash
# Wrapper de dmesg — usa el real si funciona, si no muestra logs simulados

if [[ -x /bin/dmesg.real ]]; then
  OUTPUT=$(/bin/dmesg.real "$@" 2>&1)
  if [[ $? -eq 0 && -n "$OUTPUT" ]]; then
    echo "$OUTPUT"
    exit 0
  fi
fi

