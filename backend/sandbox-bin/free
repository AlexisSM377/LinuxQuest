#!/bin/sh
# Mock educativo de free - Muestra memoria RAM y swap
# Simula la salida de free con datos de ejemplo

# Procesar argumentos
human=0
for arg in "$@"; do
  case "$arg" in
    -h|--human) human=1 ;;
    -m|--mega) human=2 ;;
    -g|--giga) human=3 ;;
    -k|--kilo) human=4 ;;
  esac
done

if [ $human -eq 1 ]; then
  cat << 'EOF'
               total        used        free      shared  buff/cache   available
Mem:           3.8Gi       1.2Gi       1.5Gi       128Mi       1.1Gi       2.3Gi
Swap:          2.0Gi          0B       2.0Gi
EOF
elif [ $human -eq 2 ]; then
  cat << 'EOF'
               total        used        free      shared  buff/cache   available
Mem:            3894        1228        1536         128        1130        2358
Swap:           2048           0        2048
EOF
elif [ $human -eq 3 ]; then
  cat << 'EOF'
               total        used        free      shared  buff/cache   available
Mem:               3           1           1           0           1           2
Swap:              2           0           2
EOF
else
  cat << 'EOF'
               total        used        free      shared  buff/cache   available
Mem:         3987456     1257472     1572864      131072     1157120     2416640
Swap:        2097152           0     2097152
EOF
fi

exit 0
