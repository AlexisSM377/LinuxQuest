#!/bin/bash
# Mock de iptables — siempre intenta el real primero, si falla usa simulación

if [[ -x /sbin/iptables ]]; then
  /sbin/iptables "$@" 2>/dev/null && exit 0
fi

if [[ "$1" == "-L" || "$1" == "-S" || "$*" == *"--list"* ]]; then
  cat <<'EOF'
Chain INPUT (policy ACCEPT)
target     prot opt source               destination
ACCEPT     all  --  anywhere             anywhere             state RELATED,ESTABLISHED
ACCEPT     icmp --  anywhere             anywhere
ACCEPT     all  --  anywhere             anywhere
ACCEPT     tcp  --  anywhere             anywhere             state NEW tcp dpt:ssh
REJECT     all  --  anywhere             anywhere             reject-with icmp-host-prohibited

Chain FORWARD (policy ACCEPT)
target     prot opt source               destination
REJECT     all  --  anywhere             anywhere             reject-with icmp-host-prohibited

Chain OUTPUT (policy ACCEPT)
target     prot opt source               destination

[NOTA: Salida simulada - el sandbox no tiene CAP_NET_ADMIN]
EOF
  exit 0
fi

if [[ "$1" == "-A" || "$1" == "-I" || "$1" == "-D" ]]; then
  echo "iptables: Regla aplicada (simulado): $*"
  echo "[NOTA: Salida simulada - este sandbox no permite modificar reglas reales de firewall]"
  exit 0
fi

cat <<'EOF'
iptables v1.8.x

Usage: iptables -[ACD] chain rule-specification [options]
       iptables -I chain [rulenum] rule-specification [options]
       iptables -L [chain [rulenum]]
       iptables -F [chain]

[NOTA: Salida simulada - sandbox sin privilegios de red]
EOF
