#!/bin/bash
# Mock de passwd - bloqueado por seguridad

USER_REQ="${1:-}"
USER_REQ_SAFE=$(printf '%s' "$USER_REQ" | tr -cd 'a-zA-Z0-9_-' | head -c 32)

cat <<EOF
[Modo educativo] passwd está bloqueado en este sandbox.

${USER_REQ_SAFE:+Cambiando contraseña para: $USER_REQ_SAFE}
${USER_REQ_SAFE:-Cambiando contraseña para usuario actual}

En un sistema real, passwd te pediría la contraseña actual y la nueva.
Esta operación está deshabilitada para proteger el entorno educativo.

Sintaxis: passwd [usuario]
EOF
exit 0
