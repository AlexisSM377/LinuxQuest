/                                                      directory          system_u:object_r:root_t:s0
/.*                                                    all files          system_u:object_r:default_t:s0
/[^/]+                                                 regular file       system_u:object_r:etc_runtime_t:s0
/bin(/.*)?                                             all files          system_u:object_r:bin_t:s0
